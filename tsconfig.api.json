{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["./api/**/*"],
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "Bundler",
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "module": "esnext",
    "paths": {}
  }
}
