{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "server/**/*",
    "./src/hono.ts",
    "./src/env.ts",
    "./server/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "Bundler",
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "module": "esnext",
    "paths": {}
  }
}